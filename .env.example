# BioAnalytiX Website — Environment Variables (example)
#
# Copy this file to `.env.local` for local development, or configure these
# values in the Vercel Project Settings → Environment Variables for deploys.
#
# ALL variables below are SERVER-ONLY. They are read exclusively inside Next.js
# Server Actions (app/actions/*) and the server-side submission strategy
# (lib/forms.ts, lib/rate-limit.ts). They are NOT prefixed with NEXT_PUBLIC_ and
# are therefore never inlined into the client bundle. (Requirements 15.4, 6.5)
#
# Do NOT commit real secrets. This file documents variable names only.

# --- Contact form (app/actions/submit-contact.ts) ---------------------------

# Required. The provider endpoint that contact submissions are POSTed to.
# If unset, the contact Server Action returns a generic delivery failure and
# retains the visitor's input (Requirement 15.5).
CONTACT_FORM_ENDPOINT=https://your-provider.example/contact

# Optional. Bearer token/API key for the contact endpoint. When set, it is sent
# as an `Authorization: Bearer <key>` header. Leave unset if the provider does
# not require authentication.
CONTACT_FORM_API_KEY=

# --- Beta / careers application form (app/actions/submit-beta.ts) -----------

# Optional. Dedicated provider endpoint for beta/careers submissions. When
# unset, the beta Server Action falls back to CONTACT_FORM_ENDPOINT above.
BETA_FORM_ENDPOINT=

# Optional. Bearer token/API key for the beta endpoint. When unset, the beta
# action falls back to CONTACT_FORM_KEY (then CONTACT_FORM_API_KEY) if present.
BETA_FORM_KEY=

# --- Rate limiting (lib/rate-limit.ts) --------------------------------------
# Both are optional. Out-of-range values are clamped to safe defaults.

# Optional. Rolling window length in seconds. Clamped to 1–3600. Default: 60.
RATE_LIMIT_WINDOW_SECONDS=60

# Optional. Maximum submissions allowed per window. Clamped to 1–1000. Default: 5.
RATE_LIMIT_MAX_SUBMISSIONS=5
